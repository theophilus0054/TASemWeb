nusa:Dish_Acang a nusa:MainDish ;
    nusa:berasal_dari nusa:Region_Ambon ;
    nusa:deskripsi "Olahan sagu dan kelapa yang dimasak menjadi dodol padat berwarna coklat. Kue tradisional Maluku untuk upacara adat."@id ;
    nusa:kategori_diet "Vegan"@id ;
    nusa:mengandung nusa:Ingredient_Kelapa,
        nusa:Ingredient_Sagu ;
    nusa:metode_memasak "Dimasak"@id ;
    nusa:nama "Acang"@id ;
    nusa:terkait_budaya nusa:Culture_Indonesia ;
    nusa:tingkat_kepedasan "Tidak Pedas"@id .

nusa:Dish_Arsik a nusa:MainDish ;
    nusa:berasal_dari nusa:Region_Tapanuli ;
    nusa:deskripsi "Ikan mas dimasak dengan andaliman (merica Batak), asam cikala, dan rempah khas Batak. Kuah berwarna kuning pekat."@id ;
    nusa:kategori_diet "Non-Vegetarian"@id ;
    nusa:mengandung nusa:Ingredient_Ikan_Mas ;
    nusa:metode_memasak "Dimasak dengan bumbu"@id ;
    nusa:nama "Arsik"@id ;
    nusa:terkait_budaya nusa:Culture_Batak ;
    nusa:tingkat_kepedasan "Pedas"@id .

nusa:Dish_Asinan_Betawi a nusa:MainDish ;
    nusa:berasal_dari nusa:Region_Jakarta ;
    nusa:deskripsi "Sayuran atau buah dalam kuah cuka asam pedas manis. Tersedia versi sayur dan buah, populer sebagai jajanan segar Jakarta."@id ;
    nusa:kategori_diet "Vegan"@id ;
    nusa:mengandung nusa:Ingredient_Buah,
