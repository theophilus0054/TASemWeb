nusa:Dish_Ayam_Taliwang a nusa:MainDish ;
    nusa:berasal_dari nusa:Region_Lombok ;
    nusa:deskripsi "Ayam kampung muda dibakar atau digoreng dengan bumbu cabai merah, terasi, dan rempah Lombok. Pedas membakar khas NTB."@id ;
